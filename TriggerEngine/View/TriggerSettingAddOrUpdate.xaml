                </TabItem>
            </TabControl>

        </StackPanel>
        <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
            <Button Name="Save" Margin="0,0,10,0" Click="Save_Click">Save</Button>
            <Button Name="Cancel" Margin="0,0,10,0" Click="Cancel_Click">Cancel</Button>
        </StackPanel>
    </Grid> 
</Window>
